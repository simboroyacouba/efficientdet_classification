# =============================================================================
# Configuration EfficientDet - Détection Toitures Cadastrales
# =============================================================================

CLASSES_FILE=classes.yaml

# =============================================================================
# DATASET
# =============================================================================

DETECTION_DATASET_IMAGES_DIR=../dataset1/images/default
DETECTION_DATASET_ANNOTATIONS_FILE=../dataset1/annotations/instances_default.json

# Dossier des images pour inférence
# Exemple Kaggle: DETECTION_INFERENCE_IMAGES_DIR=/kaggle/input/mon-dataset/test
DETECTION_INFERENCE_IMAGES_DIR=

# =============================================================================
# MODÈLE EFFICIENTDET
# =============================================================================

# Variantes disponibles (d0=léger/rapide -> d7=lourd/précis):
#   tf_efficientdet_d0  -> image 512px  (~15M params)  ← recommandé pour débuter
#   tf_efficientdet_d1  -> image 640px  (~21M params)
#   tf_efficientdet_d2  -> image 768px  (~26M params)
#   tf_efficientdet_d3  -> image 896px  (~34M params)
#   tf_efficientdet_d4  -> image 1024px (~49M params)
#   tf_efficientdet_d5  -> image 1280px (~67M params)
#   tf_efficientdet_d7  -> image 1536px (~52M params)
EFFICIENTDET_MODEL=tf_efficientdet_d0

# Taille d'image (doit correspondre au modèle ci-dessus)
IMAGE_SIZE=512

# =============================================================================
# ENTRAÎNEMENT
# =============================================================================

NUM_EPOCHS=1
BATCH_SIZE=2
LEARNING_RATE=1e-4
WEIGHT_DECAY=1e-4
GRAD_CLIP=1.0
TRAIN_SPLIT=0.70
VAL_SPLIT=0.20
TEST_SPLIT=0.10
SAVE_EVERY=5
PRETRAINED=true

# Seuil de confiance (plus bas pour EfficientDet car scores plus conservateurs)
SCORE_THRESHOLD=0.3

# =============================================================================
# SORTIE
# =============================================================================

OUTPUT_DIR=./output
EVALUATION_DIR=./evaluation
PREDICTIONS_DIR=./predictions

# Chemin vers un modèle existant (pour evaluate.py et inference.py)
# Laisser vide pour auto-détection
# MODEL_PATH=./runs/detect/train/efficientdet_XXXXXXXX_XXXXXX/best_model.pth
